---
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
	hideNav?: boolean;
}

const { title, hideNav = false } = Astro.props;
const themeCSS = Astro.locals.themeCSS ?? "";
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AIチャットやガイド付き検索で、あなたにぴったりの日本の旅先を発見しよう。47都道府県から最適な旅行先をおすすめします。" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | たびさき</title>
    <ClientRouter />
    {themeCSS && <style set:html={themeCSS} />}
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: system-ui, sans-serif;
        background: var(--md-sys-color-background, #fffbfe);
        color: var(--md-sys-color-on-background, #1c1b1f);
        min-height: 100dvh;
      }
      a {
        color: var(--md-sys-color-primary, #6750a4);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }
    </style>
  </head>
  <body>
    {!hideNav && (
      <header transition:animate="none" style="display: flex; align-items: center; padding: 12px 16px; border-bottom: 1px solid var(--md-sys-color-outline-variant, #cac4d0); gap: 16px;">
        <a href="/search" style="font-weight: 700; font-size: 18px; color: var(--md-sys-color-on-background, #1c1b1f); text-decoration: none; margin-right: auto;">たびさき</a>
        <nav aria-label="メインナビゲーション" style="display: flex; gap: 16px;">
          <a href="/search" aria-current={currentPath === "/search" ? "page" : undefined} style={`font-size: 13px; text-decoration: none; color: ${currentPath === "/search" ? "var(--md-sys-color-primary, #6750a4)" : "var(--md-sys-color-on-surface-variant, #49454f)"};${currentPath === "/search" ? " font-weight: 600;" : ""}`}>さがす</a>
          <a href="/discover" aria-current={currentPath === "/discover" ? "page" : undefined} style={`font-size: 13px; text-decoration: none; color: ${currentPath === "/discover" ? "var(--md-sys-color-primary, #6750a4)" : "var(--md-sys-color-on-surface-variant, #49454f)"};${currentPath === "/discover" ? " font-weight: 600;" : ""}`}>発見</a>
          <a href="/wishlist" aria-current={currentPath === "/wishlist" ? "page" : undefined} style={`font-size: 13px; text-decoration: none; color: ${currentPath === "/wishlist" ? "var(--md-sys-color-primary, #6750a4)" : "var(--md-sys-color-on-surface-variant, #49454f)"};${currentPath === "/wishlist" ? " font-weight: 600;" : ""} position: relative;`}>行きたい<span id="wishlist-badge" style="display: none; position: absolute; top: -6px; right: -14px; min-width: 16px; height: 16px; border-radius: 8px; background: var(--md-sys-color-tertiary, #7d5260); color: var(--md-sys-color-on-tertiary, #fff); font-size: 10px; font-weight: 700; line-height: 16px; text-align: center; padding: 0 3px;" /></a>
          <a href="/settings" aria-current={currentPath === "/settings" ? "page" : undefined} style={`font-size: 13px; text-decoration: none; color: ${currentPath === "/settings" ? "var(--md-sys-color-primary, #6750a4)" : "var(--md-sys-color-on-surface-variant, #49454f)"};${currentPath === "/settings" ? " font-weight: 600;" : ""}`}>設定</a>
        </nav>
      </header>
    )}
    <div transition:animate="fade">
      <slot />
    </div>
    <script>
      function updateBadge(count?: number) {
        const badge = document.getElementById("wishlist-badge");
        if (!badge) return;
        if (count === undefined) {
          try {
            const raw = localStorage.getItem("tabisaki_wishlist");
            count = raw ? JSON.parse(raw).items?.length ?? 0 : 0;
          } catch {
            count = 0;
          }
        }
        badge.textContent = count > 0 ? String(count) : "";
        badge.style.display = count > 0 ? "" : "none";
      }

      // Same-tab: fired by wishlist service
      window.addEventListener("wishlist-change", (e) => {
        updateBadge((e as CustomEvent).detail?.count);
      });
      // Cross-tab: fired by browser when another tab writes localStorage
      window.addEventListener("storage", (e) => {
        if (e.key === "tabisaki_wishlist") updateBadge();
      });
      // Page load / ViewTransition navigation: read from localStorage
      document.addEventListener("astro:page-load", () => updateBadge());
    </script>
  </body>
</html>
