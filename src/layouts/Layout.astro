---
import { ClientRouter } from "astro:transitions";
import styles from "./Layout.module.css";

interface Props {
	title: string;
	hideNav?: boolean;
}

const { title, hideNav = false } = Astro.props;
const themeCSS = Astro.locals.themeCSS ?? "";
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AIチャットやガイド付き検索で、あなたにぴったりの日本の旅先を発見しよう。47都道府県から最適な旅行先をおすすめします。" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | たびさき</title>
    <ClientRouter />
    {themeCSS && <style set:html={themeCSS} />}
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: system-ui, sans-serif;
        background: var(--md-sys-color-background, #fffbfe);
        color: var(--md-sys-color-on-background, #1c1b1f);
        min-height: 100dvh;
      }
      a {
        color: var(--md-sys-color-primary, #6750a4);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
      }
    </style>
  </head>
  <body>
    {!hideNav && (
      <header transition:animate="none" class={styles.header}>
        <a href="/search" class={styles.logo}>たびさき</a>
        <nav aria-label="メインナビゲーション" class={styles.nav}>
          <a href="/search" aria-current={currentPath === "/search" ? "page" : undefined} class={currentPath === "/search" ? styles.navLinkActive : styles.navLink}>さがす</a>
          <a href="/discover" aria-current={currentPath === "/discover" ? "page" : undefined} class={currentPath === "/discover" ? styles.navLinkActive : styles.navLink}>発見</a>
          <a href="/wishlist" aria-current={currentPath === "/wishlist" ? "page" : undefined} class={`${currentPath === "/wishlist" ? styles.navLinkActive : styles.navLink} ${styles.wishlistLink}`}>行きたい<span id="wishlist-badge" class={styles.badge} style="display: none;" /></a>
          <a href="/settings" aria-current={currentPath === "/settings" ? "page" : undefined} class={currentPath === "/settings" ? styles.navLinkActive : styles.navLink}>設定</a>
        </nav>
      </header>
    )}
    <div transition:animate="fade">
      <slot />
    </div>
    <script>
      function updateBadge(count?: number) {
        const badge = document.getElementById("wishlist-badge");
        if (!badge) return;
        if (count === undefined) {
          try {
            const raw = localStorage.getItem("tabisaki_wishlist");
            count = raw ? JSON.parse(raw).items?.length ?? 0 : 0;
          } catch {
            count = 0;
          }
        }
        badge.textContent = count > 0 ? String(count) : "";
        badge.style.display = count > 0 ? "" : "none";
      }

      // Same-tab: fired by wishlist service
      window.addEventListener("wishlist-change", (e) => {
        updateBadge((e as CustomEvent).detail?.count);
      });
      // Cross-tab: fired by browser when another tab writes localStorage
      window.addEventListener("storage", (e) => {
        if (e.key === "tabisaki_wishlist") updateBadge();
      });
      // Page load / ClientRouter navigation: read from localStorage
      document.addEventListener("astro:page-load", () => updateBadge());
    </script>
  </body>
</html>
