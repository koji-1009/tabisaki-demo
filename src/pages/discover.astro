---
import DiscoverPage from "../components/discover/DiscoverPage";
import activitiesData from "../data/activities.json";
import Layout from "../layouts/Layout.astro";
import { getPrefectures } from "../services/prefectures.ts";
import pageStyles from "../styles/page.module.css";
import {
	ACTIVITY_IDS,
	type Activity,
	type ActivityId,
} from "../types/index.ts";

const prefectures = getPrefectures();
const activities = activitiesData as Activity[];

const url = new URL(Astro.request.url);
const activitiesParam = url.searchParams.get("activities");
const initialActivities = activitiesParam
	? (activitiesParam
			.split(",")
			.filter((a) => ACTIVITY_IDS.includes(a as ActivityId)) as ActivityId[])
	: [];
---

<Layout title="発見">
  <main class={pageStyles.main}>
    <DiscoverPage client:idle prefectures={prefectures} activities={activities} selected={initialActivities} />
    <div class={pageStyles.chatFooter}>
      <p class={pageStyles.chatFooterText}>もっと自由に相談したい？</p>
      <a href="/chat" class={pageStyles.chatFooterLink}>
        AIチャットで相談する →
      </a>
    </div>
  </main>
</Layout>
