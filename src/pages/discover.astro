---
import DiscoverPage from "../components/discover/DiscoverPage";
import activitiesData from "../data/activities.json";
import Layout from "../layouts/Layout.astro";
import { getPrefectures } from "../services/prefectures.ts";
import {
	ACTIVITY_IDS,
	type Activity,
	type ActivityId,
} from "../types/index.ts";

const prefectures = getPrefectures();
const activities = activitiesData as Activity[];

const url = new URL(Astro.request.url);
const activitiesParam = url.searchParams.get("activities");
const initialActivities = activitiesParam
	? (activitiesParam
			.split(",")
			.filter((a) => ACTIVITY_IDS.includes(a as ActivityId)) as ActivityId[])
	: [];
---

<Layout title="発見">
  <main style="padding: 16px;">
    <DiscoverPage client:idle prefectures={prefectures} activities={activities} initialActivities={initialActivities} />
    <div style="text-align: center; margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--md-sys-color-outline-variant, #cac4d0);">
      <p style="font-size: 13px; color: var(--md-sys-color-on-surface-variant, #49454f); margin-bottom: 8px;">もっと自由に相談したい？</p>
      <a href="/chat" style="font-size: 14px; font-weight: 600; color: var(--md-sys-color-tertiary, #7d5260);">
        AIチャットで相談する →
      </a>
    </div>
  </main>
</Layout>
