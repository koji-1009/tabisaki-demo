---
import Layout from "../layouts/Layout.astro";
---

<Layout title="エラー">
  <main style="padding: 48px 16px; text-align: center;">
    <h1 style="font-size: 24px; font-weight: 700; margin-bottom: 12px;">エラーが発生しました</h1>
    <p style="font-size: 14px; color: var(--md-sys-color-on-surface-variant, #49454f); margin-bottom: 24px; line-height: 1.6;">
      申し訳ありません。ページの表示中にエラーが発生しました。
    </p>
    <a href="/search" style="display: inline-block; padding: 12px 24px; border-radius: 24px; background: var(--md-sys-color-primary, #6750a4); color: var(--md-sys-color-on-primary, #fff); font-weight: 600; text-decoration: none;">
      トップに戻る
    </a>
  </main>
</Layout>
