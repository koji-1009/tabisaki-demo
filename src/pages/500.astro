---
import Layout from "../layouts/Layout.astro";
import styles from "./500.module.css";
---

<Layout title="エラー">
  <main class={styles.main}>
    <h1 class={styles.title}>エラーが発生しました</h1>
    <p class={styles.description}>
      申し訳ありません。ページの表示中にエラーが発生しました。
    </p>
    <a href="/search" class={styles.link}>
      トップに戻る
    </a>
  </main>
</Layout>
