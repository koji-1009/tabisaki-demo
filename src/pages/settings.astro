---
import SettingsPage from "../components/settings/SettingsPage";
import Layout from "../layouts/Layout.astro";
import pageStyles from "../styles/page.module.css";
import { parseUserPrefs } from "../utils/cookies.ts";

const prefs = parseUserPrefs(Astro.request.headers.get("cookie"));
const color = prefs?.color ?? "#6750A4";
const tone = prefs?.tone ?? "vibrant";
---

<Layout title="設定">
  <main class={pageStyles.main}>
    <h1 class={pageStyles.pageTitleLarge}>設定</h1>
    <SettingsPage client:idle initialColor={color} initialTone={tone} />
  </main>
</Layout>
