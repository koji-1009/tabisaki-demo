---
import WishlistButton from "../../components/shared/WishlistButton";
import Layout from "../../layouts/Layout.astro";
import { getPrefectureById } from "../../services/prefectures.ts";

const { id } = Astro.params;
const prefecture = getPrefectureById(id ?? "");

if (!prefecture) {
	return Astro.redirect("/search");
}

// Determine back destination from Referer header
let backHref = "/search";
let backLabel = "一覧にもどる";
const referer = Astro.request.headers.get("referer");
if (referer) {
	try {
		const refPath = new URL(referer).pathname;
		if (refPath === "/discover") {
			backHref = "/discover";
			backLabel = "発見にもどる";
		} else if (refPath === "/chat") {
			backHref = "/chat";
			backLabel = "チャットにもどる";
		}
	} catch {}
}
---

<Layout title={prefecture.name}>
  <main style="padding: 0;">
    <div aria-hidden="true" style={`height: 200px; background: var(--md-sys-color-primary-container, #eaddff); display: flex; align-items: center; justify-content: center;`}>
      <span style="font-size: 48px; font-weight: 700; color: var(--md-sys-color-on-primary-container, #21005d);">
        {prefecture.name}
      </span>
    </div>

    <div style="padding: 24px 16px;">
      <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px;">
        <h1 style="font-size: 28px; font-weight: 700;">{prefecture.name}</h1>
        <span style="font-size: 14px; color: var(--md-sys-color-on-surface-variant, #49454f);">{prefecture.nameEn}</span>
      </div>

      <p style="font-size: 15px; line-height: 1.7; margin-bottom: 24px;">
        {prefecture.description}
      </p>

      <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 12px;">みどころ</h2>
      <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px;">
        {prefecture.highlights.map((h) => (
          <span style="padding: 6px 14px; border-radius: 16px; font-size: 14px; background: var(--md-sys-color-secondary-container, #e8def8); color: var(--md-sys-color-on-secondary-container, #1d192b);">
            {h}
          </span>
        ))}
      </div>

      <div style="text-align: center;">
        <WishlistButton client:load prefectureId={prefecture.id} />
      </div>

      <div style="margin-top: 24px; text-align: center;">
        <a href={backHref} style="color: var(--md-sys-color-primary, #6750a4); font-size: 14px;">
          ← {backLabel}
        </a>
      </div>
    </div>
  </main>
</Layout>
