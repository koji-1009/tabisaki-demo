---
import WishlistButton from "../../components/shared/WishlistButton";
import Layout from "../../layouts/Layout.astro";
import { getPrefectureById } from "../../services/prefectures.ts";
import styles from "./PrefectureDetail.module.css";

const { id } = Astro.params;
const prefecture = getPrefectureById(id ?? "");

if (!prefecture) {
	return Astro.redirect("/search");
}
---

<Layout title={prefecture.name}>
  <main class={styles.main}>
    <div aria-hidden="true" class={styles.hero}>
      <span class={styles.heroName}>
        {prefecture.name}
      </span>
    </div>

    <div class={styles.content}>
      <div class={styles.titleRow}>
        <h1 class={styles.title}>{prefecture.name}</h1>
        <span class={styles.titleEn}>{prefecture.nameEn}</span>
      </div>

      <p class={styles.description}>
        {prefecture.description}
      </p>

      <h2 class={styles.sectionTitle}>みどころ</h2>
      <div class={styles.highlights}>
        {prefecture.highlights.map((h) => (
          <span class={styles.highlightTag}>
            {h}
          </span>
        ))}
      </div>

      <div class={styles.wishlistArea}>
        <WishlistButton client:idle prefectureId={prefecture.id} />
      </div>

      <div class={styles.backLink}>
        <a href="/search" class={styles.backLinkText}>
          ← 一覧にもどる
        </a>
      </div>
    </div>
  </main>
</Layout>
